        'customer_id': customer['customer_id'],
        'bmi_value': bmi,
        'age_at_entry': customer['age_at_entry'],
        'blood_pressure_category': random.choice(['Low', 'Medium', 'High']),
        'smoking_flag': random.choice(['Y', 'N']),
        'alcohol_flag': random.choice(['Y', 'N']),
        'sugar_risk_category': random.choice(['Low', 'Medium', 'High']),
        'cholesterol_risk_category': random.choice(['Low', 'Medium', 'High']),
        'ecg_risk_category': random.choice(['Low', 'Medium', 'High']),
        'urine_test_risk_category': random.choice(['Low', 'Medium', 'High']),
        'liver_test_risk_category': random.choice(['Low', 'Medium', 'High']),
        'kidney_test_risk_category': random.choice(['Low', 'Medium', 'High']),
        'preexisting_condition_identified': 'Y',
