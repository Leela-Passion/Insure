# ============================================================
# DIRTY HELPERS
# ============================================================

def introduce_null(value, probability=0.03):
    return None if random.random() < probability else value


def introduce_typo(value, probability=0.05):
    if random.random() > probability:
        return value

    variations = {
        'Active': ['ACTIVE', 'active', 'Actve'],
        'Lapsed': ['LAPSED', 'lapse', 'Lapsee'],
        'Male': ['M', 'male', 'MALE'],
        'Female': ['F', 'female', 'FEMALE'],
        'Andhra Pradesh': ['AP', 'A.P', 'andhrapradesh'],
        'Tamil Nadu': ['TN', 'Tamilnadu'],
        'Maharashtra': ['MH', 'Maharastra']
    }

    if value in variations:
        return random.choice(variations[value])

    return value


def dirty_phone(phone):
    options = [
        phone,
        '+91' + phone,
        '91-' + phone,
        '0' + phone,
        phone[:5] + '-' + phone[5:],
        phone + 'abc',
        'INVALID'
    ]

    return random.choice(options)


def dirty_amount(amount):
    options = [
        amount,
        f'₹{amount}',
        f'{amount} INR',
        str(amount),
        'forty thousand',
        None
    ]

    return random.choice(options)


def random_date(start_year=2018, end_year=2025):
    start = datetime(start_year, 1, 1)
    end = datetime(end_year, 12, 31)
    delta = end - start
    return start + timedelta(days=random.randint(0, delta.days))

# ============================================================
# REGION TABLE
